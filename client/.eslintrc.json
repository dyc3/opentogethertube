{
	"root": true,
	"env": {
		"node": true,
		"es6": true,
		"browser": true
	},
	"plugins": ["vitest"],
	"extends": [
		"eslint:recommended",
		"plugin:vue/base",
		"plugin:vue/essential",
		"@vue/typescript/recommended"
	],
	"rules": {
		"no-console": "off",
		"no-debugger": "off",
		"curly": "off",
		"camelcase": "error",
		"no-eval": "off",
		"no-multiple-empty-lines": "off",
		"no-var": "off",
		"no-dupe-keys": "off",
		"no-prototype-builtins": "off",
		"prefer-arrow-callback": "off",
		"eol-last": "off",
		"eqeqeq": "off",
		"no-unused-vars": "off",
		"no-regex-spaces": "off",
		"no-redeclare": "off",
		"no-mixed-spaces-and-tabs": "off",
		"vue/no-v-model-argument": "off",
		"vue/multi-word-component-names": "off",
		"vue/no-multiple-template-root": "off",
		"vue/no-reserved-component-names": "off",

		// Covered by Biome's Vue domain/rules.
		"vue/no-arrow-functions-in-watch": "off",
		"vue/no-ref-as-operand": "off",
		"vue/no-use-v-if-with-v-for": "off",
		"vue/valid-v-bind": "off",
		"vue/valid-v-else": "off",
		"vue/valid-v-else-if": "off",
		"vue/valid-v-for": "off",
		"vue/valid-v-if": "off",
		"vue/next-tick-style": "off",
		"vue/valid-v-on": "off",
		"vue/no-reserved-props": "off",
		"vue/mustache-interpolation-spacing": "off",
		"vitest/no-identical-title": "off",
		"vitest/consistent-test-it": "off",

		"@typescript-eslint/no-var-requires": "warn"
	},
	"parserOptions": {
		"ecmaVersion": 2018,
		"sourceType": "module"
	},
	"overrides": [
		{
			"files": ["*.js"],
			"rules": {
				"@typescript-eslint/explicit-module-boundary-types": "off",
				"@typescript-eslint/no-var-requires": "off",
				"@typescript-eslint/no-unused-vars": "off"
			}
		},
		{
			"files": ["*.ts", "*.tsx"],
			"parser": "@typescript-eslint/parser",
			"parserOptions": {
				"ecmaVersion": 2018,
				"sourceType": "module",
				"project": ["./tsconfig.json"]
			},
			"rules": {
				"no-unused-vars": "off",
				"@typescript-eslint/no-unused-vars": "off",
				"@typescript-eslint/adjacent-overload-signatures": "off",
				"@typescript-eslint/switch-exhaustiveness-check": "off",
				"@typescript-eslint/restrict-template-expressions": "warn",
				"@typescript-eslint/no-unnecessary-type-assertion": "warn",
				"@typescript-eslint/no-unnecessary-boolean-literal-compare": "warn",

				"@typescript-eslint/no-unsafe-call": "off", // TODO: switch to warn
				"@typescript-eslint/no-unsafe-member-access": "off", // TODO: switch to warn
				"@typescript-eslint/no-unsafe-assignment": "off" // TODO: switch to warn
			}
		}
	]
}
